# Recommended DeepSeek remote provider
# Create an API key in the DeepSeek platform, then set either DEEPSEEK_API_KEY
# or the generic LLM_API_KEY. Do not commit your real key.
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=sk-...

# Optional controlled same-domain follow-up search. Without this key, the AI
# pipeline still follows relevant links already present on official pages.
# BRAVE_SEARCH_API_KEY=your-brave-search-key

# Ollama local alternative
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://localhost:11434
# LLM_MODEL=qwen3.5:9b
# LLM_API_KEY=ollama

# LM Studio alternative
# First manually load the model in LM Studio and start the local server.
# Confirm the model id with:
# curl.exe http://localhost:1234/v1/models
# For the current LM Studio setup, the API model id is:
# qwen2.5-7b-instruct
#
# Then set:
# LLM_PROVIDER=lmstudio
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_MODEL=qwen2.5-7b-instruct
# LLM_API_KEY=lm-studio
