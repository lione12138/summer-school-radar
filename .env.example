# Recommended DeepSeek remote provider
# Create an API key in the DeepSeek platform, then set either DEEPSEEK_API_KEY
# or the generic LLM_API_KEY. The same DEEPSEEK_API_KEY also powers build-time
# Chinese translation. Do not commit your real key.
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=sk-...

# Optional broad discovery. This is used only when a scan explicitly enables
# discovery; discovered pages remain labelled as discovery sources.
# SERPER_API_KEY=your-serper-key
# SERPER_SEARCH_API_KEY is also accepted as a compatibility alias.

# Optional controlled same-domain follow-up refinement. Without this key, the
# AI pipeline still follows relevant links already present on official pages.
# BRAVE_SEARCH_API_KEY=your-brave-search-key
